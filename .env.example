# Environment variables — TEMPLATE (committed; no real values here).
# Copy this file to .env.local and fill in the real values there.
# .env.local is gitignored and never leaves your machine.
#
# The same app is deployed ONCE PER ENTITY (e.g. BJ PPC → USD, WMI → GBP):
# one repo, multiple Vercel projects, each with its own copy of these vars.
# Code never branches on entity — it only reads this config (src/lib/config.ts).

# --- Entity / brand (per deployment) ---
# Legal entity behind this deployment, e.g. "BJ PPC sp. z o.o. trading as PPC Mastery".
ENTITY_LEGAL_NAME=
# Brand shown in the UI (wordmark, titles, wizard header).
BRAND_NAME=
# Optional logo image URL; empty = text wordmark.
BRAND_LOGO_URL=
# ISO 4217 currency for all prices: USD for BJ PPC, GBP for WMI.
CURRENCY=
# VAT percentage + number — used on quotes/invoices from Phase 2.
VAT_RATE=
VAT_NUMBER=
# Reporting-only deployment (e.g. "MCC Command Center"): "true" hides the
# onboarding funnel (no New client / contract / payment) — only Add managed
# account + dashboards + weekly reports. Leave empty for the full portal.
PORTAL_REPORTING_ONLY=

# --- Stripe (per deployment — each entity has its own Stripe account) ---
# TEST mode keys until the loop is proven; live keys only after.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Slack (client channels) ---
# Bot token (xoxb-...) with channels:manage, channels:read, chat:write,
# users:read, users:read.email. Empty = Slack step records email only.
SLACK_BOT_TOKEN=
# Team members auto-added to every client channel (comma-separated emails).
SLACK_TEAM_EMAILS=
# Emails clients grant GA4/GTM/Search Console/Merchant Center access to. Empty = reuse SLACK_TEAM_EMAILS.
ACCESS_GRANT_EMAILS=
# Our Meta Business Manager ID — shown to clients to add us as a Partner (Meta access task).
META_BUSINESS_ID=
# Internal Slack channel for weekly report drafts (e.g. #weekly-report-drafts).
SLACK_REVIEW_CHANNEL=

# --- Google Ads API (account linking from the entity's MCC hierarchy) ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Rexos P5-Lite controlled writes (all default OFF/empty = propose-only) ---
# Kill switch: writes refuse unless exactly "true".
GOOGLE_ADS_WRITE_ENABLED=
# Account allowlist (comma-separated customer ids); ships as the test account.
GOOGLE_ADS_WRITE_CUSTOMERS=
# Campaign allowlist (required for pause/budget writes).
GOOGLE_ADS_WRITE_CAMPAIGNS=
# "Open the whole book": when true, MCC membership alone gates and the account
# allowlist is lifted. Leave unset/false during rollout.
ALLOW_ALL_MCC_ACCOUNTS=
# Budget caps (0 for GOOGLE_ADS_BUDGET_MAX_DAILY disables budget writes entirely).
GOOGLE_ADS_BUDGET_MAX_DAILY=
GOOGLE_ADS_BUDGET_MAX_INCREASE_PCT=
GOOGLE_ADS_BUDGET_LARGE_DECREASE_PCT=

# --- Contract provider ---
# "pandadoc" (default when unset — app.wmiltd.com) or "proposal-engine"
# (self-hosted engine — entity clones). Selects which backend the contract
# step uses; only that provider's vars below need real values.
CONTRACT_PROVIDER=

# --- PandaDoc (contract provider when CONTRACT_PROVIDER is unset/pandadoc) ---
PANDADOC_API_KEY=
# The contract template's id (Templates list via API or template URL).
PANDADOC_TEMPLATE_ID=
# Shared key from PandaDoc webhook settings (verifies webhook signatures).
PANDADOC_WEBHOOK_KEY=

# --- Proposal engine (contract provider when CONTRACT_PROVIDER=proposal-engine) ---
# Base URL of the self-hosted engine, e.g. https://proposals.webmarketinginternational.com
PROPOSAL_ENGINE_URL=
# The engine's API_TOKEN secret (protects its /api/*).
PROPOSAL_ENGINE_API_TOKEN=
# The engine's WEBHOOK_SECRET — verifies X-Signature on /api/webhooks/proposal-engine.
# Also set the engine's WEBHOOK_URL secret to https://<this portal>/api/webhooks/proposal-engine
PROPOSAL_ENGINE_WEBHOOK_SECRET=

# --- Supabase (server-side only; the Next.js backend uses these) ---
# From Supabase → Project Settings → API Keys (the "Publishable and secret" tab).
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# --- Auth0 (login) ---
# Domain + Client ID from Auth0 → Applications → your app → Settings.
# Client Secret from the same page (sensitive). AUTH0_SECRET is a 32-byte hex
# string for cookie encryption: generate with `openssl rand -hex 32`.
# APP_BASE_URL is this app's own URL (http://localhost:3000 locally;
# https://ppcmastery.vercel.app in production).
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=
# Namespaced claim the tenant's post-login Action stamps roles under (must
# match the Action code exactly). Empty = the legacy default
# "https://ppcmastery.app/roles" (the original tenant's namespace).
AUTH0_ROLES_CLAIM=

# --- Anthropic (LLM-worded weekly report narratives) ---
# API key (sk-ant-...). Empty = weekly report uses the bulleted template only.
ANTHROPIC_API_KEY=

# --- Cron (Vercel scheduled jobs auth; generate any long random string) ---
CRON_SECRET=
# Optional: Slack channel id/name for team nags. Empty = the client channel.
SLACK_OPS_CHANNEL=
